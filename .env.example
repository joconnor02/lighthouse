LIGHTHOUSE_AUTH_TOKEN=change-me-please
# Or set a fixed token / LIGHTHOUSE_AUTH_DISABLED=true for local work.
# With the default above, an auto-… token is persisted in backend/.lighthouse_auth_token
# so uvicorn --reload does not rotate it and break the UI.
# LIGHTHOUSE_AUTH_DISABLED=false
LIGHTHOUSE_BIND_HOST=127.0.0.1
LIGHTHOUSE_BIND_PORT=8000
LIGHTHOUSE_DB_PATH=lighthouse.db
# Skip nmap host discovery on each process start (5m schedule still runs).
# Recommended for local --reload; leave unset/true for production-like runs.
LIGHTHOUSE_DISCOVERY_ON_STARTUP=false
